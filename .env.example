# =============================================================================
# ShamarConnect — exemplo de variáveis de ambiente (SEM segredos reais).
# Copie para .env.local e preencha. .env.local NUNCA é versionado.
# =============================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ACTIVE_MESSAGING_PROVIDER=mock

# Sessão (assinatura HMAC-SHA256 do cookie — mín. 32 chars, segredo)
# Gerar: openssl rand -base64 48
SESSION_SECRET=

# Supabase (app principal)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
INTERNAL_API_KEY=

# Supabase Suite (auth central — tenants/app_users)
NEXT_PUBLIC_SUITE_SUPABASE_URL=
NEXT_PUBLIC_SUITE_SUPABASE_ANON_KEY=
SUITE_SUPABASE_SERVICE_ROLE_KEY=

# Cron (worker da fila de envio /api/cron/outbox). Vercel Cron envia
# Authorization: Bearer <CRON_SECRET>. Se vazio, cai no INTERNAL_API_KEY.
CRON_SECRET=

# Resend (e-mail)
RESEND_API_KEY=
RESEND_FROM_EMAIL="ShamarConnect <noreply@shamarconnect.com.br>"

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Modelo de transcrição de áudio (Marco 1.5). Ex.: whisper-1 ou gpt-4o-mini-transcribe.
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# WhatsApp Web Gateway (serviço Node separado — whatsapp-web.js)
WHATSAPP_WEB_GATEWAY_URL=http://localhost:8787
WHATSAPP_WEB_GATEWAY_TOKEN=

# Meta WhatsApp Cloud API (oficial)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_BUSINESS_ACCOUNT_ID=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_APP_SECRET=

# Meta App (Login / Instagram / Messenger DMs)
META_APP_ID=
META_APP_SECRET=
META_SOCIAL_VERIFY_TOKEN=

# Evolution API (Baileys)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_TENANT_ID=
EVOLUTION_ORGANIZATION_ID=

# Asaas (cobrança)
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
SHAMARCONNECT_WEBHOOK_TOKEN=

# Automação — Lips Agent
# Cooldown para autoenvio controlado (minutos). Default: 5
AUTO_REPLY_COOLDOWN_MINUTES=5
# Token de segurança para endpoint /api/agents/lips/process-jobs (opcional)
LIPS_PROCESSOR_TOKEN=
# ID da organização Lips (para testes)
LIPS_ORGANIZATION_ID=

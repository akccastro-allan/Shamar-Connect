# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session (HMAC-SHA256 cookie signing — min 32 chars, keep secret)
# Generate: openssl rand -base64 48
SESSION_SECRET=
NEXT_PUBLIC_ACTIVE_MESSAGING_PROVIDER=mock

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
INTERNAL_API_KEY=

# Cron (worker da fila de envio /api/cron/outbox). Vercel Cron envia
# Authorization: Bearer <CRON_SECRET>. Se vazio, cai no INTERNAL_API_KEY.
CRON_SECRET=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="ShamarConnect <noreply@shamarconnect.com.br>"

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# WhatsApp Web Lab Gateway
# Deve apontar para um serviço Node.js separado rodando whatsapp-web.js + Puppeteer.
WHATSAPP_WEB_GATEWAY_URL=http://localhost:8787
WHATSAPP_WEB_GATEWAY_TOKEN=change-me

# Meta WhatsApp Cloud API official provider
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=
